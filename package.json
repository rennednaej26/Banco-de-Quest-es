{
  "name": "banco-questoes-ai",
  "version": "1.0.0",
  "description": "MVP de banco de questoes, flashcards e revisao inteligente para concursos.",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "electron": "npm run build && electron .",
    "electron:dev": "electron .",
    "dist": "npm run build && electron-builder",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@supabase/supabase-js": "^2.106.2",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "next": "^16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.17",
    "typescript": "^6.0.3"
  },
  "build": {
    "appId": "com.bancoai.questoes",
    "productName": "Banco AI",
    "directories": { "output": "dist" },
    "files": ["electron/**/*", "out/**/*", "package.json"],
    "win": {
      "target": ["nsis", "portable"],
      "artifactName": "Banco-AI-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Banco AI"
    }
  }
}
